  {
    "id": "LE013",
    "standard_id": "char_diaochan",
    "name_cn": "神貂蝉",
    "name_en": "God Diao Chan",
    "gender": "Female",
    "faction": "God",
    "health": 3,
    "power_index": 4.5,
    "traits_cn": [
      "控制",
      "进攻",
      "困难"
    ],
    "traits_en": [
      "Control",
      "Aggressive",
      "High Difficulty"
    ],
    "expansion": "God",
    "skills": [
      "skill_god_soul_lure",
      "skill_god_bewitching_heart"
    ],
    "faq": [
      {
        "q_cn": "神貂蝉发动技能「魅魂」并声明花色，若其没有，是谁判断？可能对方有但不愿交给你算不算没有？",
        "a_cn": "目标角色若有声明花色的牌，必须选择其中一张交给神貂蝉，不能选择让神貂蝉观看手牌并弃牌。",
        "q_en": "When God Diao Chan uses [Soul Lure] and declares a suit, who decides if the target has that suit? Can the target refuse to give a matching card?",
        "a_en": "If the target has a card of the declared suit, they must give one to God Diao Chan. They cannot choose to let her view and discard instead."
      },
      {
        "q_cn": "目标角色的回合改为由你操控具体指什么意思？",
        "a_cn": "神貂蝉观看其手牌并代其执行此回合所有阶段。",
        "q_en": "What does it mean for God Diao Chan to take control of another character's turn?",
        "a_en": "God Diao Chan views that character's hand and executes all phases of their turn on their behalf."
      },
      {
        "q_cn": "由神貂蝉操控对方进行回合时能否发动对方技能？如果允许发动对方技能的话，所有的发动条件是以对方为判断还是以貂蝉判断，例如距离、攻击范围内外等？",
        "a_cn": "神貂蝉操控对方可以发动其技能，所有发动条件以目标角色为判断基准。",
        "q_en": "During a controlled turn, can God Diao Chan activate the target's skills? If so, are conditions like distance and attack range evaluated from the target's perspective or Diao Chan's?",
        "a_en": "Yes, she may use the controlled character's skills. All conditions are evaluated from the controlled character's perspective."
      },
      {
        "q_cn": "由神貂蝉操控对方进行回合时能否令对方发动神貂蝉自身技能？",
        "a_cn": "不能。",
        "q_en": "While controlling another character's turn, can God Diao Chan use her own skills through the controlled character?",
        "a_en": "No."
      },
      {
        "q_cn": "如果神貂蝉控制对方，杀死神貂蝉自己，后续如何结算处理？",
        "a_cn": "即使神貂蝉死亡，神貂蝉仍然正常进行完目标角色的当前回合。",
        "q_en": "If during a controlled turn the controlled character kills God Diao Chan herself, what happens?",
        "a_en": "Even if God Diao Chan dies, she continues to complete the controlled character's current turn normally."
      },
      {
        "q_cn": "当一名拥有2个或更多「魅惑」标记的角色回合即将开始时，若其武将牌处于背面朝上的状态，如何结算？",
        "a_cn": "「惑心」的技能触发时机晚于武将牌从背面翻转至正面朝上，因此玩家翻面后跳过该角色的这一回合，不会触发「惑心」，「魅惑」标记保留。",
        "q_en": "When a character with 2+ Bewitch tokens is about to begin their turn while their general card is face-down, how is this resolved?",
        "a_en": "[Bewitching Heart] triggers after the card flips face-up. The character's turn is then skipped — [Bewitching Heart] does not trigger and the Bewitch tokens are retained."
      }
    ]
  },
